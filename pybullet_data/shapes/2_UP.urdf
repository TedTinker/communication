<?xml version="1.0"?>
<robot name="2_up">
  <!-- Definition of the invisible base with invisible sides -->

  <link name="base">
    <visual>
      <geometry>
        <box size=".1 .99 .99"/>
      </geometry>
      <material name="base_material">
        <color rgba="0 0 0 0"/> 
      </material>
    </visual>
    <collision>
      <geometry>
          <box size=".1 .99 .99"/>
      </geometry>
    </collision>
    <inertial>
        <mass value="0"/>
        <inertia ixx="0.0" ixy="0.0" ixz="0.0" iyy="0.0" iyz="0.0" izz="0.0"/>
    </inertial>
  </link>

  <link name="left">
    <visual>
      <geometry>
        <box size=".2 0.2 1"/>
      </geometry>
      <material name="left_material">
        <color rgba="1 0 0 0"/> 
      </material>
    </visual>
    <collision>
      <geometry>
          <box size=".2 0.2 1"/>
      </geometry>
    </collision>
    <inertial>
        <mass value="0"/>
        <inertia ixx="0.0" ixy="0.0" ixz="0.0" iyy="0.0" iyz="0.0" izz="0.0"/>
    </inertial>
  </link>

  <link name="top">
    <visual>
      <geometry>
        <box size="0.2 1 0.2"/>
      </geometry>
      <material name="top_material">
        <color rgba="0 1 0 0"/> 
      </material>
    </visual>
    <collision>
      <geometry>
          <box size=".2 1 0.2"/>
      </geometry>
    </collision>
    <inertial>
        <mass value="0"/>
        <inertia ixx="0.0" ixy="0.0" ixz="0.0" iyy="0.0" iyz="0.0" izz="0.0"/>
    </inertial>
  </link>

  <link name="right">
    <visual>
      <geometry>
        <box size="0.2 0.2 1"/>
      </geometry>
      <material name="right_material">
        <color rgba="0 0 1 0"/> 
      </material>
    </visual>
    <collision>
      <geometry>
          <box size=".2 0.2 1"/>
      </geometry>
    </collision>
    <inertial>
        <mass value="0"/>
        <inertia ixx="0.0" ixy="0.0" ixz="0.0" iyy="0.0" iyz="0.0" izz="0.0"/>
    </inertial>
  </link>

  <link name="bottom">
    <visual>
      <geometry>
        <box size="0.2 1 0.2"/>
      </geometry>
      <material name="bottom_material">
        <color rgba="0 1 1 0"/> 
      </material>
    </visual>
    <collision>
      <geometry>
          <box size=".2 1 0.2"/>
      </geometry>
    </collision>
    <inertial>
        <mass value="0"/>
        <inertia ixx="0.0" ixy="0.0" ixz="0.0" iyy="0.0" iyz="0.0" izz="0.0"/>
    </inertial>
  </link>

  <!-- Joints connecting base to the sides -->
  <joint name="joint1" type="fixed">
    <parent link="base"/>
    <child link="left"/>
    <origin xyz="0 -.6 0" rpy="0 0 0"/>
  </joint>

  <joint name="joint2" type="fixed">
    <parent link="base"/>
    <child link="top"/>
    <origin xyz="0 0 .6" rpy="0 0 0"/>
  </joint>

  <joint name="joint3" type="fixed">
    <parent link="base"/>
    <child link="right"/>
    <origin xyz="0 .6 0" rpy="0 0 0"/>
  </joint>

  <joint name="joint4" type="fixed">
    <parent link="base"/>
    <child link="bottom"/>
    <origin xyz="0 0 -.6" rpy="0 0 0"/>
  </joint>

  <!-- Definition of the shape-->
  <link name="larger">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.2 1 .5"/>
      </geometry>
      <material name="red">
        <color rgba="1 0 0 1"/>
      </material>
    </visual>
    <inertial>
        <mass value="0"/>
        <inertia ixx="0.0" ixy="0.0" ixz="0.0" iyy="0.0" iyz="0.0" izz="0.0"/>
    </inertial>
  </link>

  <joint name="joint5" type="fixed">
    <parent link="base"/>
    <child link="larger"/>
    <origin xyz="0 0 .25" rpy="0 0 0"/>
  </joint>

  <link name="smaller">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.2 .25 .5"/>
      </geometry>
      <material name="red">
        <color rgba="1 0 0 1"/>
      </material>
    </visual>
    <inertial>
        <mass value="0"/>
        <inertia ixx="0.0" ixy="0.0" ixz="0.0" iyy="0.0" iyz="0.0" izz="0.0"/>
    </inertial>
  </link>

  <joint name="joint6" type="fixed">
    <parent link="base"/>
    <child link="smaller"/>
    <origin xyz="0 0 -.25" rpy="0 0 0"/>
  </joint>

</robot>