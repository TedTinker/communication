<?xml version="1.0"?>

<robot name="robot">

    <!-- Robot's body -->
    <link name="body_link">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="1"/>
            <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="1 1 1"/>
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="1 1 1"/>
            </geometry>
        </collision>
    </link>
	
    <!-- Robot's nose -->
    <link name="nose_link">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="1"/>
            <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size=".2 .2 .2"/>
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size=".2 .2 .2"/>
            </geometry>
        </collision>
    </link>
	
    <!-- Joint: base, nose -->
    <joint name="body_nose_joint" type="fixed">
        <parent link="body_link"/>
        <child link="nose_link"/>
        <origin xyz=".6 0 0" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>

    <!-- Robot's shoulder -->
    <link name="shoulder_link">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="1"/>
            <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size=".1 0.1 0.1"/>
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size=".1 0.1 0.1"/>
            </geometry>
        </collision>
    </link>

    <!-- Joint: base, shoulder -->
    <joint name="body_shoulder_joint" type="continuous">
        <parent link="body_link"/>
        <child link="shoulder_link"/>
        <origin xyz="0 .5 0" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>

    <!-- Robot's arm -->
    <link name="arm_link">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="1"/>
            <inertia ixx="0" ixy="0.0" ixz="0.0" iyy="0.0" iyz="0.0" izz="0.0"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="2 0.1 0.1"/>
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="2 0.1 0.1"/>
            </geometry>
        </collision>
    </link>

	<!-- Joint: shoulder, arm -->
    <joint name="shoulder_arm_joint" type="fixed"> 
        <parent link="shoulder_link"/> 
        <child link="arm_link"/> 
        <origin xyz="1 0 0" rpy="0 0 0"/> 
        <axis xyz="1 0 0"/> 
    </joint>

</robot>