<?xml version="1.0"?>

<robot name="robot">

    <!-- Robot's body -->
    <link name="body">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="100"/>
            <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="1 1 1"/>
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="1 1 1"/>
            </geometry>
        </collision>
    </link>
	
    <!-- Robot's nose -->
    <link name="nose">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0"/>
            <inertia ixx="0.0" ixy="0.0" ixz="0.0" iyy="0.0" iyz="0.0" izz="0.0"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size=".2 .2 .2"/>
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size=".2 .2 .2"/>
            </geometry>
        </collision>
    </link>
	
    <!-- Joint: base, nose -->
    <joint name="body_nose_joint" type="fixed">
        <parent link="body"/>
        <child link="nose"/>
        <origin xyz=".6 0 0" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>

    <!-- Robot's body_sensor -->
    <link name="body_sensor">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0"/>
            <inertia ixx="0" ixy="0.0" ixz="0.0" iyy="0.0" iyz="0.0" izz="0.0"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="1.21 1.01 1.01"/>
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="1.21 1.01 1.01"/>
            </geometry>
        </collision>
    </link>

	<!-- Joint: body, body_sensor -->
    <joint name="body_body_sensor_joint" type="fixed"> 
        <parent link="body"/> 
        <child link="body_sensor"/> 
        <origin xyz=".1 0 0" rpy="0 0 0"/> 
        <axis xyz="0 0 0"/> 
    </joint>



    <!-- Robot's shoulder -->
    <link name="shoulder">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0"/>
            <inertia ixx="0.0" ixy="0.0" ixz="0.0" iyy="0.0" iyz="0.0" izz="0.0"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size=".1 0.1 0.1"/>
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size=".1 0.1 0.1"/>
            </geometry>
        </collision>
    </link>

    <!-- Joint: body, shoulder -->
    <joint name="body_shoulder_joint" type="continuous">
        <parent link="body"/>
        <child link="shoulder"/>
        <origin xyz="0 .5 0" rpy="0 0 0"/>
        <axis xyz="0 -1 0"/>
    </joint>



    <!-- Robot's arm -->
    <link name="arm">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0"/>
            <inertia ixx="0" ixy="0.0" ixz="0.0" iyy="0.0" iyz="0.0" izz="0.0"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="3 0.1 0.1"/>
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="3 0.1 0.1"/>
            </geometry>
        </collision>
    </link>

	<!-- Joint: shoulder, arm -->
    <joint name="shoulder_arm_joint" type="fixed"> 
        <parent link="shoulder"/> 
        <child link="arm"/> 
        <origin xyz="1.5 0 0" rpy="0 0 0"/> 
        <axis xyz="1 0 0"/> 
    </joint>

    <!-- Robot's arm-sensor -->
    <link name="arm_sensor">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0"/>
            <inertia ixx="0" ixy="0.0" ixz="0.0" iyy="0.0" iyz="0.0" izz="0.0"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="3 0.11 0.11"/>
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="3 0.11 0.11"/>
            </geometry>
        </collision>
    </link>

	<!-- Joint: arm, arm_sensor -->
    <joint name="arm_arm_sensor_joint" type="fixed"> 
        <parent link="arm"/> 
        <child link="arm_sensor"/> 
        <origin xyz="0 0 0" rpy="0 0 0"/> 
        <axis xyz="0 0 0"/> 
    </joint>



    <!-- Robot's hand -->
    <link name="hand">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0"/>
            <inertia ixx="0" ixy="0.0" ixz="0.0" iyy="0.0" iyz="0.0" izz="0.0"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="0.1 2 0.1"/>
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="0.1 2 0.1"/>
            </geometry>
        </collision>
    </link>

	<!-- Joint: arm, hand -->
    <joint name="arm_hand_joint" type="fixed"> 
        <parent link="arm"/> 
        <child link="hand"/> 
        <origin xyz="1.5 0 0" rpy="0 0 0"/> 
        <axis xyz="0 0 1"/> 
    </joint>

    <!-- Robot's hand-sensor -->
    <link name="hand_sensor">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0"/>
            <inertia ixx="0" ixy="0.0" ixz="0.0" iyy="0.0" iyz="0.0" izz="0.0"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="0.11 2 0.11"/>
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="0.11 2 0.11"/>
            </geometry>
        </collision>
    </link>

	<!-- Joint: hand, hand_sensor -->
    <joint name="hand_hand_sensor_joint" type="fixed"> 
        <parent link="hand"/> 
        <child link="hand_sensor"/> 
        <origin xyz="0 0 0" rpy="0 0 0"/> 
        <axis xyz="0 0 0"/> 
    </joint>

</robot>