            <geometry>
                <box size="0.1 0.1 0.1"/>
            </geometry>
        </collision>
    </link>
    <!-- Joint: arm_1, elbow_pitch -->
    <joint name="arm_1_elbow_pitch_joint" type="revolute">
        <parent link="arm_1"/>
        <child link="elbow_pitch"/>
        <origin xyz="0 0 0.55"
                rpy="0 0 0"/>
        <axis xyz="1 0 0"/>
        <limit lower="-1.5" upper="0" effort="100" velocity="10"/>
