<?xml version="1.0"?>
<robot name="robot">


    <!-- base -->
    <link name="base">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="100"/>
            <inertia ixx=".1" ixy=".1" ixz=".1" iyy=".1" iyz=".1" izz=".1"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.75" length="0.1"/>
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.75" length="0.1"/>
            </geometry>
        </collision>
    </link>


    <!-- body -->
    <link name="body">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0.1"/>
            <inertia ixx=".1" ixy=".1" ixz=".1" iyy=".1" iyz=".1" izz=".1"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="1 1 2"/>
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="1 1 2"/>
            </geometry>
        </collision>
    </link>
    <!-- Joint: base, body -->
    <joint name="base_body_joint" type="continuous">
        <parent link="base"/>
        <child link="body"/>
        <origin xyz="0 0 1.05"
                rpy="0 0 0"/>
        <axis xyz="0 0 1"/>
        
    </joint>


    <!-- shoulder_pitch -->
    <link name="shoulder_pitch">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0.1"/>
            <inertia ixx=".1" ixy=".1" ixz=".1" iyy=".1" iyz=".1" izz=".1"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="0.2 0.1 0.1"/>
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="0.2 0.1 0.1"/>
            </geometry>
        </collision>
    </link>
    <!-- Joint: body, shoulder_pitch -->
    <joint name="body_shoulder_pitch_joint" type="revolute">
        <parent link="body"/>
        <child link="shoulder_pitch"/>
        <origin xyz="0.5 -0.55 0"
                rpy="0 0 0"/>
        <axis xyz="0 -1 0"/>
        <limit lower="-1.5" upper="0" effort="100" velocity="10"/>
    </joint>


    <!-- shoulder_roll -->
    <link name="shoulder_roll">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0.1"/>
            <inertia ixx=".1" ixy=".1" ixz=".1" iyy=".1" iyz=".1" izz=".1"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="0.1 0.1 0.1"/>
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="0.1 0.1 0.1"/>
            </geometry>
        </collision>
    </link>
    <!-- Joint: shoulder_pitch, shoulder_roll -->
    <joint name="shoulder_pitch_shoulder_roll_joint" type="revolute">
        <parent link="shoulder_pitch"/>
        <child link="shoulder_roll"/>
        <origin xyz="0.15 0 0"
                rpy="0 0 0"/>
        <axis xyz="1 0 0"/>
        <limit lower="0" upper="1.5" effort="100" velocity="10"/>
    </joint>


    <!-- arm_1 -->
    <link name="arm_1">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="0.1"/>
            <inertia ixx=".1" ixy=".1" ixz=".1" iyy=".1" iyz=".1" izz=".1"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="0.1 0.1 1"/>
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="0.1 0.1 1"/>
            </geometry>
        </collision>
    </link>
    <!-- Joint: shoulder_roll, arm_1 -->
    <joint name="shoulder_roll_arm_1_joint" type="fixed">
        <parent link="shoulder_roll"/>
        <child link="arm_1"/>
        <origin xyz="0 0 0.55"
                rpy="0 0 0"/>
        <axis xyz="0 -1 0"/>
        
    </joint>


    <!-- elbow_pitch -->
    <link name="elbow_pitch">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
