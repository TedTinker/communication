<?xml version="1.0"?>
<robot name="robot">


    <!-- base -->
    <link name="base">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="100"/>
            <inertia ixx=".1" ixy=".1" ixz=".1" iyy=".1" iyz=".1" izz=".1"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.75" length="0.1"/>
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <cylinder radius="0.75" length="0.1"/>
            </geometry>
        </collision>
    </link>


    <!-- body -->
    <link name="body">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="10"/>
            <inertia ixx=".1" ixy=".1" ixz=".1" iyy=".1" iyz=".1" izz=".1"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="1 1 2"/>
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="1 1 2"/>
            </geometry>
        </collision>
    </link>
    <!-- Joint: base, body -->
    <joint name="base_body_joint" type="continuous">
        <parent link="base"/>
        <child link="body"/>
        <origin xyz="0 0 1.05"
                rpy="0 0 0"/>
        <axis xyz="0 0 1"/>
        <limit lower="0" upper="0" effort="0" velocity="0"/>
    </joint>


    <!-- shoulder_pitch -->
    <link name="shoulder_pitch">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="10"/>
            <inertia ixx=".1" ixy=".1" ixz=".1" iyy=".1" iyz=".1" izz=".1"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="0.2 0.1 0.1"/>
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="0.2 0.1 0.1"/>
            </geometry>
        </collision>
    </link>
    <!-- Joint: body, shoulder_pitch -->
    <joint name="body_shoulder_pitch_joint" type="revolute">
        <parent link="body"/>
        <child link="shoulder_pitch"/>
        <origin xyz="0.5 -0.55 0"
                rpy="0 0 0"/>
        <axis xyz="0 -1 0"/>
        <limit lower="-1.5" upper="0" effort="100" velocity="10"/>
    </joint>


    <!-- arm_1 -->
    <link name="arm_1">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="10"/>
            <inertia ixx=".1" ixy=".1" ixz=".1" iyy=".1" iyz=".1" izz=".1"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="0.1 1.5 0.1"/>
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="0.1 1.5 0.1"/>
            </geometry>
        </collision>
    </link>
    <!-- Joint: shoulder_pitch, arm_1 -->
    <joint name="shoulder_pitch_arm_1_joint" type="prismatic">
        <parent link="shoulder_pitch"/>
        <child link="arm_1"/>
        <origin xyz="0.15 0 0.7"
                rpy="-1.5707 0 0"/>
        <axis xyz="0 -1 0"/>
        <limit lower="-1" upper="0" effort="100" velocity="10"/>
    </joint>


    <!-- hand_0 -->
    <link name="hand_0">
