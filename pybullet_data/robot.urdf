<?xml version="1.0"?>

<robot name="robot">

    <!-- Robot's body -->
    <link name="body_link">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="1"/>
            <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="1 1 1"/>
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size="1 1 1"/>
            </geometry>
        </collision>
    </link>
	
    <!-- Robot's nose -->
    <link name="nose_link">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="1"/>
            <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size=".2 .2 .2"/>
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size=".2 .2 .2"/>
            </geometry>
        </collision>
    </link>
	
    <!-- Joint: base, nose -->
    <joint name="body_nose_joint" type="fixed">
        <parent link="body_link"/>
        <child link="nose_link"/>
        <origin xyz=".6 0 0" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>
	
    <!-- Robot's upper nose -->
    <link name="upper_nose_link">
        <inertial>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <mass value="1"/>
            <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
        </inertial>
        <visual>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size=".1 .1 .1"/>
            </geometry>
        </visual>
        <collision>
            <origin xyz="0 0 0" rpy="0 0 0"/>
            <geometry>
                <box size=".1 .1 .1"/>
            </geometry>
        </collision>
    </link>
	
    <!-- Joint: base, upper nose -->
    <joint name="body_upper_nose_joint" type="fixed">
        <parent link="body_link"/>
        <child link="upper_nose_link"/>
        <origin xyz=".55 0 .15" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>

    <!-- Robot's left arm -->
    <link name="left_arm_link">
        <inertial>
            <origin xyz=".5 .5 0" rpy="0 0 0"/>
            <mass value="1"/>
            <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
        </inertial>
        <visual>
            <origin xyz=".5 .5 0" rpy="0 0 0"/>
            <geometry>
                <box size="1 0.1 0.1"/>
            </geometry>
        </visual>
        <collision>
            <origin xyz=".5 .5 0" rpy="0 0 0"/>
            <geometry>
                <box size="1 0.1 0.1"/>
            </geometry>
        </collision>
    </link>

    <!-- Joint: base, left arm -->
    <joint name="body_left_arm_joint" type="continuous">
        <parent link="body_link"/>
        <child link="left_arm_link"/>
        <origin xyz="0.5 0 0" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>
	
	<!-- Robot's left hand -->
	<link name="left_hand_link">
		<inertial>
			<origin xyz="0 0 .25" rpy="0 0 0"/>
			<mass value="1"/>
			<inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
		</inertial>
		<visual>
			<origin xyz="0 0 .25" rpy="0 0 0"/>
			<geometry>
				<box size="0.1 0.1 0.5"/>
			</geometry>
		</visual>
		<collision>
			<origin xyz="0 0 .25" rpy="0 0 0"/>
			<geometry>
				<box size="0.1 0.1 0.5"/>
			</geometry>
		</collision>
	</link>

	<!-- Joint: left arm, left hand -->
	<joint name="left_arm_left_hand_joint" type="continuous">
		<parent link="left_arm_link"/>
		<child link="left_hand_link"/>
		<origin xyz="1 .5 0" rpy="0 0 0"/>
		<axis xyz="1 0 0"/>
	</joint>
	
    <!-- Robot's right arm -->
    <link name="right_arm_link">
        <inertial>
            <origin xyz=".5 -.5 0" rpy="0 0 0"/>
            <mass value="1"/>
            <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
        </inertial>
        <visual>
            <origin xyz=".5 -.5 0" rpy="0 0 0"/>
            <geometry>
                <box size="1 0.1 0.1"/>
            </geometry>
        </visual>
        <collision>
            <origin xyz=".5 -.5 0" rpy="0 0 0"/>
            <geometry>
                <box size="1 0.1 0.1"/>
            </geometry>
        </collision>
    </link>

    <!-- Joint: base, right arm -->
    <joint name="body_right_arm_joint" type="continuous">
        <parent link="body_link"/>
        <child link="right_arm_link"/>
        <origin xyz="0.5 0 0" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>
	
	<!-- Robot's right hand -->
	<link name="right_hand_link">
		<inertial>
			<origin xyz="0 0 .25" rpy="0 0 0"/>
			<mass value="1"/>
			<inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
		</inertial>
		<visual>
			<origin xyz="0 0 .25" rpy="0 0 0"/>
			<geometry>
				<box size="0.1 0.1 0.5"/>
			</geometry>
		</visual>
		<collision>
			<origin xyz="0 0 .25" rpy="0 0 0"/>
			<geometry>
				<box size="0.1 0.1 0.5"/>
			</geometry>
		</collision>
	</link>

	<!-- Joint: right arm, right hand -->
	<joint name="right_arm_right_hand_joint" type="continuous">
		<parent link="right_arm_link"/>
		<child link="right_hand_link"/>
		<origin xyz="1 -.5 0" rpy="0 0 0"/>
		<axis xyz="1 0 0"/>
	</joint>

</robot>